{
  "manifest_version": 3,
  "name": "7000單自動點擊",
  "version": "2.0",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["https://yh7000.org/quiz/play/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://yh7000.org/quiz/play/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}